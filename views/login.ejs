<div class="login-container">
    <div class="login-card glass">
        <h2>Connexion</h2>
        <% if (error) { %>
            <p style="color: var(--danger); margin-bottom: 1rem;"><%= error %></p>
        <% } %>
        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="username">Nom d'utilisateur</label>
                <input type="text" id="username" name="username" required placeholder="admin ou membre">
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" required placeholder="admin123 ou membre123">
            </div>
            <button type="submit" class="btn btn-primary">Se connecter</button>
        </form>
    </div>
</div>
