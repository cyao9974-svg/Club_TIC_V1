<div class="auth-wrapper">
    <div class="auth-card glass center-card">
        <h2><i class="fas fa-shield-alt text-cyan"></i> Administration</h2>
        <p class="subtitle">Accédez aux outils de gestion réservés au bureau.</p>
        
        <% if (error) { %>
            <p style="color: var(--danger); background: rgba(239, 68, 68, 0.1); padding: 0.8rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--danger);">
                <i class="fas fa-exclamation-triangle"></i> <%= error %>
            </p>
        <% } %>
        
        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="email"><i class="fas fa-envelope"></i> E-mail Professionnel</label>
                <input type="email" id="email" name="email" required placeholder="admin@clubtic.ci" autocomplete="email">
            </div>
            <div class="form-group">
                <label for="password"><i class="fas fa-lock"></i> Mot de passe</label>
                <input type="password" id="password" name="password" required placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
                <i class="fas fa-sign-in-alt"></i> Se connecter
            </button>
        </form>
    </div>
</div>
