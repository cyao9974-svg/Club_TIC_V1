<div class="container">
    <div class="dashboard-header">
        <div>
            <h1 style="font-size: 2.2rem; color: #fff;">Tableau de Bord</h1>
            <p class="text-muted">Gérez les membres et suivez les statistiques du club.</p>
        </div>
        
        <% if (user && user.role === 'admin') { %>
            <a href="/members/export" class="btn btn-primary"><i class="fas fa-file-excel"></i> Exporter la Liste</a>
        <% } else { %>
            <div class="badge badge-cyan"><i class="fas fa-eye"></i> Mode Lecture Seule</div>
        <% } %>
    </div>

    <div class="stats-grid">
        <div class="stat-card glass">
            <i class="fas fa-users"></i>
            <div class="stat-value"><%= stats.total %></div>
            <div class="stat-label">Total Membres</div>
        </div>
        <div class="stat-card glass">
            <i class="fas fa-chart-bar"></i>
            <div class="stat-value"><%= stats.participations %></div>
            <div class="stat-label">Participations Cumulées</div>
        </div>
        <div class="stat-card glass">
            <i class="fas fa-chalkboard-teacher"></i>
            <div class="stat-value"><%= stats.classes %></div>
            <div class="stat-label">Classes Actives</div>
        </div>
    </div>

    <div class="glass" style="padding: 2rem;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 2rem; align-items: center;">
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" onkeyup="searchTable()" placeholder="Rechercher par nom, prénom, classe...">
            </div>
        </div>

        <div class="table-wrapper">
            <table id="dataTable">
                <thead>
                    <tr>
                        <th width="5%">ID</th>
                        <th width="15%">Nom</th>
                        <th width="15%">Prénom</th>
                        <th width="10%">Classe</th>
                        <th width="15%">Filière</th>
                        <th width="15%">Téléphone</th>
                        <th width="10%" style="text-align: center;">Participation</th>
                        <% if (user && user.role === 'admin') { %>
                            <th width="15%" style="text-align: right;">Actions Admin</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% members.forEach(member => { %>
                        <tr>
                            <td class="text-muted">#<%= member.id %></td>
                            <td style="font-weight: 600; color: #fff;"><%= member.nom %></td>
                            <td style="color: #fff;"><%= member.prenom %></td>
                            <td><span class="badge badge-cyan"><%= member.classe %></span></td>
                            <td><%= member.filiere %></td>
                            <td><%= member.telephone || 'N/A' %></td>
                            <td style="text-align: center;">
                                <span class="badge" style="background: rgba(255,255,255,0.1); color: #fff;">
                                    <%= member.nb_participation || 0 %> pts
                                </span>
                            </td>
                            <% if (user && user.role === 'admin') { %>
                                <td style="text-align: right;">
                                    <div class="actions" style="justify-content: flex-end;">
                                        <!-- Increment participation -->
                                        <form action="/members/increment/<%= member.id %>" method="POST" style="display: inline;">
                                            <button type="submit" title="Ajouter Participation" class="icon-btn"><i class="fas fa-plus-circle text-cyan"></i></button>
                                        </form>
                                        <!-- Delete -->
                                        <form action="/members/delete/<%= member.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Vraiment supprimer ce membre ?');">
                                            <button type="submit" title="Supprimer" class="icon-btn danger"><i class="fas fa-trash-alt"></i></button>
                                        </form>
                                    </div>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <% if (members.length === 0) { %>
                <div class="text-center" style="padding: 3rem 1rem;">
                    <i class="fas fa-folder-open text-muted" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                    <p class="text-muted">Aucun membre enregistré pour le moment.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
