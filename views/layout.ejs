<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Club TIC - <%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav>
        <div class="logo">CLUB TIC</div>
        <ul class="nav-links" style="display: flex;">
            <li><a href="/"><i class="fas fa-home"></i> Accueil</a></li>
            <li><a href="/dashboard"><i class="fas fa-list"></i> Liste des Membres</a></li>
            <% if (user) { %>
                <% if (user.role === 'admin') { %>
                    <li><a href="/members/export"><i class="fas fa-file-excel"></i> Export Excel</a></li>
                <% } %>
                <li><a href="/auth/logout" style="color: var(--danger);"><i class="fas fa-sign-out-alt"></i> Quitter (<%= user.nom %>)</a></li>
            <% } else { %>
                <li><a href="/auth/login"><i class="fas fa-lock"></i> Administration</a></li>
            <% } %>
        </ul>
    </nav>

    <div class="container">
        <%- body %>
    </div>

    <footer style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.8rem;">
        &copy; 2026 Club TIC - Tous droits réservés
    </footer>
</body>
</html>
