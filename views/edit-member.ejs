<div style="max-width: 600px; margin: 0 auto;">
    <div class="glass" style="padding: 2.5rem;">
        <h2 style="margin-bottom: 2rem;"><i class="fas fa-user-edit"></i> Modifier un Membre</h2>
        <form action="/members/edit/<%= member.id %>" method="POST">
            <div class="form-group">
                <label for="nom">Nom</label>
                <input type="text" id="nom" name="nom" value="<%= member.nom %>" required>
            </div>
            <div class="form-group">
                <label for="prenom">Prénom</label>
                <input type="text" id="prenom" name="prenom" value="<%= member.prenom %>" required>
            </div>
            <div class="form-group">
                <label for="classe">Classe</label>
                <select id="classe" name="classe" required>
                    <option value="BTS1" <%= member.classe === 'BTS1' ? 'selected' : '' %>>BTS1</option>
                    <option value="BTS2" <%= member.classe === 'BTS2' ? 'selected' : '' %>>BTS2</option>
                    <option value="Licence1" <%= member.classe === 'Licence1' ? 'selected' : '' %>>Licence1</option>
                    <option value="Licence2" <%= member.classe === 'Licence2' ? 'selected' : '' %>>Licence2</option>
                    <option value="Licence3" <%= member.classe === 'Licence3' ? 'selected' : '' %>>Licence3</option>
                </select>
            </div>
            <div class="form-group">
                <label for="contact">Contact</label>
                <input type="text" id="contact" name="contact" value="<%= member.contact %>" required>
            </div>
            <div class="form-group">
                <label for="participation">Nombre de participation</label>
                <input type="number" id="participation" name="participation" value="<%= member.participation %>" min="0">
            </div>
            <div class="form-group">
                <label for="date_inscription">Date d'inscription</label>
                <input type="text" id="date_inscription" name="date_inscription" value="<%= member.date_inscription %>">
                <small style="color: var(--text-muted)">Format: YYYY-MM-DD HH:mm:ss</small>
            </div>
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary">Mettre à jour</button>
                <a href="/dashboard" class="btn" style="background: rgba(255,255,255,0.1); color: white;">Annuler</a>
            </div>
        </form>
    </div>
</div>
