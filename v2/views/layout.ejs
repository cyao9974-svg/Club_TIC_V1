<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Club TIC V2 - <%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav>
        <div class="logo">
            <i class="fas fa-microchip text-cyan"></i>
            NTIC <span>CLUB</span> 2025-2026
        </div>
        <ul class="nav-links">
            <li><a href="/" class="<%= title.includes('Accueil') ? 'active' : '' %>"><i class="fas fa-home"></i> Accueil</a></li>
            <li><a href="/dashboard" class="<%= title.includes('Bord') ? 'active' : '' %>"><i class="fas fa-chart-line"></i> Tableau de bord</a></li>
            <% if (user && user.role === 'admin') { %>
                <li><a href="/auth/logout" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
            <% } else { %>
                <li><a href="/auth/login" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.9rem; color: #000;"><i class="fas fa-lock"></i> Espace Admin</a></li>
            <% } %>
        </ul>
    </nav>

    <main>
        <%- body %>
    </main>

    <footer style="text-align: center; padding: 3rem 1rem; color: var(--text-muted); font-size: 0.9rem; border-top: 1px solid var(--glass-border); margin-top: 5rem; background: rgba(0,0,0,0.2);">
        <p>&copy; 2026 NTIC Club V2 - Conçu avec une architecture Hybride Cloud/Local.</p>
    </footer>

    <script>
        function searchTable() {
            let input = document.getElementById("searchInput");
            if (!input) return;
            let filter = input.value.toLowerCase();
            let table = document.getElementById("dataTable");
            if (!table) return;
            let tr = table.getElementsByTagName("tr");
            for (let i = 1; i < tr.length; i++) {
                let text = tr[i].innerText.toLowerCase();
                tr[i].style.display = text.includes(filter) ? "" : "none";
            }
        }
    </script>
</body>
</html>
