<div class="dashboard-header">
    <h1>Tableau de Bord</h1>
    <% if (user.role === 'admin') { %>
        <a href="/members/add" class="btn btn-primary" style="width: auto; padding: 0.8rem 1.5rem;">
            <i class="fas fa-plus"></i> Ajouter un Membre
        </a>
    <% } %>
</div>

<div class="stats-grid">
    <div class="stat-card glass">
        <h3>Total Membres</h3>
        <div class="value"><%= stats.total %></div>
    </div>
    <div class="stat-card glass">
        <h3>Participations Totales</h3>
        <div class="value"><%= stats.participations %></div>
    </div>
    <div class="stat-card glass">
        <h3>Classes Actives</h3>
        <div class="value"><%= stats.classes %></div>
    </div>
</div>

<div class="glass" style="padding: 1.5rem; margin-bottom: 2rem;">
    <div style="display: flex; gap: 1rem; align-items: center;">
        <i class="fas fa-search" style="color: var(--text-muted);"></i>
        <input type="text" id="searchInput" placeholder="Rechercher par nom, prénom ou classe..." 
               style="flex: 1; background: transparent; border: none; color: white; outline: none; font-size: 1.1rem;"
               onkeyup="filterMembers()">
    </div>
</div>

<div class="table-container glass">
    <table id="membersTable">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Classe</th>
                <th>Contact</th>
                <th>Participation</th>
                <th>Date Inscription</th>
                <% if (user.role === 'admin') { %>
                    <th>Actions</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% members.forEach(member => { %>
                <tr>
                    <td><%= member.nom %></td>
                    <td><%= member.prenom %></td>
                    <td><span class="badge badge-<%= member.classe.toLowerCase() %>"><%= member.classe %></span></td>
                    <td><%= member.contact %></td>
                    <td style="text-align: center;">
                        <strong><%= member.participation %></strong>
                        <% if (user.role === 'admin') { %>
                            <button onclick="incrementParticipation(<%= member.id %>)" 
                                    style="background: none; border: none; color: var(--primary); cursor: pointer; margin-left: 10px;">
                                <i class="fas fa-plus-circle"></i>
                            </button>
                        <% } %>
                    </td>
                    <td><%= member.date_inscription %></td>
                    <% if (user.role === 'admin') { %>
                        <td>
                            <a href="/members/edit/<%= member.id %>" style="color: var(--primary); margin-right: 15px;"><i class="fas fa-edit"></i></a>
                            <a href="#" onclick="deleteMember(<%= member.id %>)" style="color: var(--danger);"><i class="fas fa-trash"></i></a>
                        </td>
                    <% } %>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<script>
function filterMembers() {
    let input = document.getElementById('searchInput');
    let filter = input.value.toLowerCase();
    let table = document.getElementById('membersTable');
    let tr = table.getElementsByTagName('tr');

    for (let i = 1; i < tr.length; i++) {
        let tdNom = tr[i].getElementsByTagName('td')[0];
        let tdPrenom = tr[i].getElementsByTagName('td')[1];
        let tdClasse = tr[i].getElementsByTagName('td')[2];
        if (tdNom || tdPrenom || tdClasse) {
            let txtValue = (tdNom.textContent || tdNom.innerText) + ' ' + 
                           (tdPrenom.textContent || tdPrenom.innerText) + ' ' + 
                           (tdClasse.textContent || tdClasse.innerText);
            if (txtValue.toLowerCase().indexOf(filter) > -1) {
                tr[i].style.display = "";
            } else {
                tr[i].style.display = "none";
            }
        }
    }
}

async function incrementParticipation(id) {
    if (confirm('Incrémenter la participation de ce membre ?')) {
        const response = await fetch(`/members/increment/${id}`, { method: 'POST' });
        if (response.ok) location.reload();
    }
}

async function deleteMember(id) {
    if (confirm('Êtes-vous sûr de vouloir supprimer ce membre ?')) {
        const response = await fetch(`/members/delete/${id}`, { method: 'POST' });
        if (response.ok) location.reload();
    }
}
</script>
